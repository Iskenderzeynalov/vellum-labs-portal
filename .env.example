# ══════════════════════════════════════════════════════════════════
# Vellum Labs Client Portal — Environment Variables
# ══════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
#   1. Copy this file to .env.local (for local dev) — never commit .env.local
#   2. Fill in the values below
#   3. In production, add these as Cloudflare Pages environment variables
#      (not in this file)
#
# WHERE TO FIND EACH VALUE:
#   NOTION_TOKEN          → notion.com → Settings → My connections → Develop integrations
#   NOTION_*_DB_ID        → Open the database in Notion → copy the ID from the URL
#                           URL format: notion.so/{workspace}/{DATABASE_ID}?v=...
#
# ══════════════════════════════════════════════════════════════════

# ─── Notion ───────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_CLIENTS_DB_ID=
NOTION_PROJECTS_DB_ID=
NOTION_TASKS_DB_ID=
NOTION_REPORTS_DB_ID=
NOTION_MEETINGS_DB_ID=
NOTION_LINKS_DB_ID=
NOTION_INVOICES_DB_ID=
NOTION_CLIENT_REQUESTS_DB_ID=

# ─── Local Development Only ───────────────────────────────────────
# Used as the "logged in" email when Cloudflare Access is not active.
# In production, this is IGNORED — Cloudflare Access provides the email.
# Set this to your own email or a test client email while developing locally.
DEV_AUTH_EMAIL=you@example.com
